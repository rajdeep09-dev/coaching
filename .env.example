# OpenCode Premium UI/UX Configuration
# Copy this file to .env and fill in your API keys

# ==========================================
# REQUIRED: AI Model Providers
# ==========================================

# Anthropic Claude (Recommended - Best for code generation)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (Optional - Alternative provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ==========================================
# REQUIRED: UI Component Libraries
# ==========================================

# 21st.dev Magic (Essential for AI component generation)
# Get your key at: https://21st.dev/magic/console
TWENTY_FIRST_DEV_API_KEY=your-21st-dev-api-key-here

# ==========================================
# OPTIONAL: Additional Providers
# ==========================================

# Groq (Fast inference, optional)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# OpenRouter (Access multiple models, optional)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ==========================================
# OPTIONAL: GitHub Copilot
# ==========================================

# GitHub Token (for Copilot models)
# Get your token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ==========================================
# CLOUD PROVIDERS (Optional)
# ==========================================

# Google Vertex AI
VERTEXAI_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=us-central1
GEMINI_API_KEY=your-gemini-api-key

# AWS Bedrock
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_API_VERSION=2024-02-01

# ==========================================
# LOCAL MODELS (Optional)
# ==========================================

# Self-hosted model endpoint
LOCAL_ENDPOINT=http://localhost:11434/v1

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

# Default shell (adjust for your system)
SHELL=/bin/bash

# Node environment
NODE_ENV=development

# Debug mode (set to true for verbose logging)
DEBUG=false