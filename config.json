{
  "_comment": "OpenCode Configuration - FREE Models + Premium MCPs for Fast Error-Free Building",
  "data": {
    "directory": ".opencode"
  },
  "providers": {
    "openai": {
      "apiKey": "${OPENAI_API_KEY}",
      "disabled": true
    },
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}",
      "disabled": true
    },
    "copilot": {
      "disabled": true
    },
    "groq": {
      "apiKey": "${GROQ_API_KEY}",
      "disabled": true
    },
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "disabled": false
    }
  },
  "agents": {
    "coder": {
      "model": "openrouter/minimax/minimax-01",
      "maxTokens": 32000,
      "temperature": 0.1
    },
    "task": {
      "model": "openrouter/nvidia/llama-3.1-nemotron-70b-instruct",
      "maxTokens": 16000,
      "temperature": 0.2
    },
    "title": {
      "model": "openrouter/moonshotai/kimi-k2",
      "maxTokens": 100,
      "temperature": 0.3
    }
  },
  "shell": {
    "path": "/bin/bash",
    "args": ["-l"]
  },
  "mcpServers": {
    "21st-dev-magic": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${TWENTY_FIRST_DEV_API_KEY}"
      },
      "description": "21st.dev Magic MCP - AI-powered UI component generation from natural language. Like v0 in your IDE. 20+ layouts, 35+ components, 19 animations."
    },
    "magic-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@magicuidesign/mcp@latest"],
      "env": {},
      "description": "Magic UI MCP - Blur fade animations, marquee logos, grid backgrounds, premium animated components."
    },
    "aceternity-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "aceternityui-mcp@latest"],
      "env": {},
      "description": "Aceternity UI MCP - Cinematic 3D components with parallax effects and premium animations."
    },
    "shadcn-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@magnusrodseth/shadcn-mcp-server@latest"],
      "env": {},
      "description": "Shadcn UI MCP - 200+ accessible components. Forms, dialogs, tables, dropdowns."
    },
    "tailwind-css": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@carbonodev/tailwindcss-mcp-server@latest"],
      "env": {},
      "description": "Tailwind CSS MCP - Utility classes, color palettes, responsive design assistance."
    },
    "motion-dev": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "motion-dev-mcp@latest"],
      "env": {},
      "description": "Motion.dev MCP - Production-ready animations for React, JavaScript, Vue."
    },
    "framer-motion": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@picardraphael/mcp-server-documentation@latest"],
      "env": {},
      "description": "Documentation MCP - Next.js, Tailwind, Framer Motion docs with intelligent search."
    },
    "rive-animations": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@astralisone/rive-mcp-server@latest"],
      "env": {},
      "description": "Rive MCP - Interactive animations and micro-interactions for web."
    }
  },
  "lsp": {
    "typescript": {
      "disabled": false,
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "tailwindcss": {
      "disabled": false,
      "command": "tailwindcss-language-server",
      "args": ["--stdio"]
    },
    "html": {
      "disabled": false,
      "command": "html-languageserver",
      "args": ["--stdio"]
    },
    "css": {
      "disabled": false,
      "command": "css-languageserver",
      "args": ["--stdio"]
    },
    "json": {
      "disabled": false,
      "command": "json-languageserver",
      "args": ["--stdio"]
    }
  },
  "debug": false,
  "ui": {
    "theme": "dark",
    "animations": {
      "enabled": true,
      "reducedMotion": false
    }
  },
  "features": {
    "autoComplete": true,
    "codeActions": true,
    "hoverInfo": true,
    "diagnostics": true,
    "formatOnSave": true
  },
  "workflow": {
    "strategy": "parallel-mcps",
    "maxSimultaneousTools": 8,
    "errorRecovery": "retry-once",
    "buildMode": "incremental"
  }
}